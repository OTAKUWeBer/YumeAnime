{
    "version": 2,
    "builds": [
      {
        "src": "api/app.py",
        "use": "@vercel/python"
      }
    ],
    "routes": [
      {
        "src": "/(.*)",
        "dest": "api/app.py"
      }
    ],
    "env": {
      "MY_VARIABLE": "value",
      "SECRET_KEY": "mysecretkey"
    }
  }
  